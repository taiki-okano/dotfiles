# See: man pkg-config
prefix=/home/ubuntu/.pyenv/versions/3.8.2
exec_prefix=${prefix}
libdir=/home/ubuntu/.pyenv/versions/3.8.2/lib
includedir=${prefix}/include

Name: Python
Description: Build a C extension for Python
Requires:
Version: 3.8
Libs.private: -lcrypt -lpthread -ldl  -lutil -lm
Libs:
Cflags: -I${includedir}/python3.8
